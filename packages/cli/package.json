{
  "name": "@atomyx/cli",
  "version": "0.1.0",
  "private": true,
  "description": "Atomyx unified CLI — single binary that routes to all Atomyx modules.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/main.js",
  "bin": {
    "atomyx": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test $(find src -name '*.test.ts')"
  },
  "dependencies": {
    "@atomyx/shared": "0.1.0",
    "@atomyx/core": "0.1.0",
    "@atomyx/driver": "0.1.0",
    "@atomyx/android-driver": "0.1.0",
    "@atomyx/ios-driver": "0.1.0",
    "@atomyx/script": "0.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
