{
  "name": "@atomyx/core-driver-cli",
  "version": "0.1.0",
  "private": true,
  "description": "Atomyx core-driver CLI — `atomyx-driver` binary that wires the framework, drivers, and MCP server into a single command-line entry point. The Pure Developer persona's primary install.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "bin": {
    "atomyx-driver": "./dist/main.js"
  },
  "exports": {
    ".": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test $(find src -name '*.test.ts')"
  },
  "dependencies": {
    "@atomyx/core-driver": "0.1.0",
    "@atomyx/core-driver-android": "0.1.0",
    "@atomyx/core-driver-ios": "0.1.0",
    "@atomyx/core-driver-mcp": "0.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
