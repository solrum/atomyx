<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened runtime is required for the bundle signature.
         disable-library-validation allows dlopen of CoreSimulator
         and SimulatorKit — both are private Xcode frameworks not
         registered in the shared cache. No sandbox — this helper
         spawns under Studio, not a distributed app. -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <false/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
