{
  "name": "@atomyx/studio",
  "version": "0.1.0",
  "private": true,
  "description": "Atomyx Studio — desktop IDE for authoring, validating, and running Atomyx YAML test scripts on real devices. macOS only in this release.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --no-watch",
    "tauri:build": "tauri build",
    "typecheck": "tsc -b",
    "lint": "eslint src --ext .ts,.tsx",
    "depcruise": "depcruise --config .dependency-cruiser.cjs src",
    "lint:feature-api": "node scripts/check-feature-api.mjs",
    "test": "node scripts/check-feature-api.mjs && node --import tsx --test $(find src -name '*.test.ts' -o -name '*.test.tsx')",
    "test:domain": "node --import tsx --test $(find src/domain -name '*.test.ts')",
    "test:coverage": "c8 node --import tsx --test $(find src -name '*.test.ts' -o -name '*.test.tsx')"
  },
  "dependencies": {
    "@atomyx/script": "0.1.0",
    "@atomyx/shared": "0.1.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.453.0",
    "monaco-editor": "^0.52.0",
    "monaco-yaml": "^5.2.0",
    "mp4box": "^0.5.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^2.5.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^10.0.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "c8": "^10.1.3",
    "dependency-cruiser": "^16.4.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
