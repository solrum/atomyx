# Atomyx iOS driver — physical device configuration template
#
# Copy this file to `device.env` (gitignored) and fill in your values.
# The Makefile auto-loads `device.env` via `-include` — no command-line
# args needed once the file exists.
#
#     cp device.env.example device.env
#     # edit device.env with your values
#     make serve-device
#
# All variables here can still be overridden on the command line:
#     make serve-device DEVICE_UDID=<other-udid>
# — Make's precedence puts command-line overrides above file values.

# ─────────────────────────────────────────────────────────────────────
# DEVICE_UDID — UDID of the physical iPhone / iPad
#
# Discover via:
#   idevice_id -l                              # libimobiledevice
#   xcrun xctrace list devices                 # Xcode tools
#   Xcode → Window → Devices and Simulators    # GUI
# ─────────────────────────────────────────────────────────────────────
DEVICE_UDID=00008101-001D14D13493003A

# ─────────────────────────────────────────────────────────────────────
# DEV_TEAM — Apple Developer Team ID (10-char alphanumeric)
#
# Find at https://developer.apple.com/account → Membership.
# Required for code signing. Xcode uses Automatic signing with this
# team; the provisioning profile is created and managed by Xcode.
# ─────────────────────────────────────────────────────────────────────
DEV_TEAM=ABCD123456

# ─────────────────────────────────────────────────────────────────────
# BUNDLE_ID — product bundle identifier for the host app
#
# Must be unique within your Apple Developer team. The default below
# works for most contributors; override if:
#   - You're on a shared team and someone else already registered it
#   - You want to keep dev builds separate from other drivers
#
# Overriding BUNDLE_ID only affects the host app target. The test
# bundle uses a derived id (`${BUNDLE_ID}.tests`) — handled inside
# project.yml, no extra var needed.
# ─────────────────────────────────────────────────────────────────────
BUNDLE_ID=dev.atomyx.driver.host

# ─────────────────────────────────────────────────────────────────────
# IPROXY_PORT — host ↔ device port for the usbmux tunnel (optional)
#
# Defaults to 22087 (same as simulator). Change if the port conflicts
# with another tool on your host. The Swift driver binds this port
# inside the device process regardless — iproxy bridges host:port ↔
# device:port.
# ─────────────────────────────────────────────────────────────────────
# IPROXY_PORT=22087
