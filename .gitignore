pnpm-lock.yaml
yarn.lock

# ─── Android / Kotlin / Gradle ─────────────────────────────────────
# Gradle build outputs (anywhere in tree)
**/build/
**/.gradle/
**/.kotlin/
**/.cxx/
**/captures/
**/.externalNativeBuild/
**/local.properties
# Android-specific
android/app/release/
android/app/debug/
android/keystores/
android/key.properties
*.apk
*.aab
*.ap_
*.dex
*.class
*.jar
!gradle/wrapper/gradle-wrapper.jar
*.aar
*.so
hs_err_pid*
# Kotlin compiler / KMP
kotlin-js-store/
.kotlintest/

# ─── iOS / Xcode ───────────────────────────────────────────────────
# Catches build output anywhere in the tree (Atomyx iOS agent,
# Flutter example apps, future native iOS harnesses).
**/DerivedData/
**/Pods/
**/*.xcworkspace/xcuserdata/
**/*.xcodeproj/xcuserdata/
**/*.xcodeproj/project.xcworkspace/xcuserdata/

# ─── Flutter / Dart ────────────────────────────────────────────────
# Build caches, analysis tool state, and generated iOS/Android
# plumbing for any Flutter app in the tree (examples/atomyx-demo,
# future Flutter harnesses).
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/Generated.xcconfig
**/flutter_export_environment.sh
**/ios/Flutter/ephemeral/

# ─── IDE / Editor ──────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws
*.swp
*.swo
*~

# ─── OS ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Atomyx local state ────────────────────────────────────────────
.atomyx/
.mcp.json

# ─── .claude/ — local-only config + cached state, EXCEPT docs/rules/ ───
# .claude/docs/ and .claude/rules/ hold contributor + AI-agent
# documentation and coding rules that MUST be tracked (so
# collaborators and future Claude sessions can read them). Settings,
# caches, and per-machine state stay ignored.
.claude/*
!.claude/docs/
!.claude/docs/**
!.claude/rules/
!.claude/rules/**

# ─── iOS agent per-contributor config ──────────────────────────────
# device.env holds DEVICE_UDID / DEV_TEAM / BUNDLE_ID per contributor.
# Template committed as device.env.example; real config is local only.
# AtomyxDriver.xcodeproj is regenerated by xcodegen on `make setup`,
# so it is local-only as well.
platforms/ios-agent/device.env
platforms/ios-agent/AtomyxDriver.xcodeproj/

# local-development
atomyx-local/

# ─── Local-only dev scripts ────────────────────────────────────────
# Every directory named `scripts/` in the tree holds per-contributor
# self-test and probe scripts — not part of the shipped surface.
# Contributors who need them author / recreate them locally.
scripts/

# ─── Rust / Cargo ──────────────────────────────────────────────────
# Cargo build output for every crate in the tree (currently
# `apps/studio/src-tauri`). Crates regenerate this on each build.
**/target/
Cargo.lock.bak

# ─── Tauri ─────────────────────────────────────────────────────────
# Per-machine generated Tauri context (capabilities schema, etc.).
**/src-tauri/gen/

# ─── Local-only design docs ───────────────────────────────────────
# ADRs and proposals are internal design deliberations. They live
# on disk next to the rest of `.claude/docs/` so local tooling can
# reference them, but they are NOT pushed — each collaborator keeps
# their own local copies.
.claude/docs/decisions/
.claude/docs/proposals/
