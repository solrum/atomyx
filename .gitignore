# ─── Node / TypeScript ─────────────────────────────────────────────
node_modules/
**/node_modules/
dist/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/
.turbo/
.swc/
coverage/
*.tsbuildinfo
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.yarn/
*.log

# Repo uses npm workspaces with package-lock.json. Stray pnpm/yarn
