# esbuild@0.27 runs a postinstall script (install.js) that falls back to a live
# registry.npmjs.org download when its platform-specific optional package is not
# present on disk. Several other transitive devDependencies (rollup, acorn,
# eventsource, postcss-selector-parser) run TypeScript builds or `husky install`
# calls via their `prepare` hook — none of which are meaningful at install time
# outside their own development environment. Suppressing all lifecycle scripts
# avoids the network fetch and the spurious build invocations during `npm ci`.
# The esbuild binary itself is shipped as an optional platform package
# (@esbuild/darwin-arm64 etc.) and resolves correctly without the postinstall.
# If a dependency is ever added that genuinely requires a postinstall to function,
# invoke it explicitly after `npm ci` in the relevant workflow step.
ignore-scripts=true
