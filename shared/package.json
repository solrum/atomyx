{
  "name": "@atomyx/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-module contracts — types plus zod schemas that validate them at runtime. Consumed by core, driver, script, mcp, cli, studio.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./script": "./dist/script/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test $(find src -name '*.test.ts')",
    "api:check": "api-extractor run",
    "api:update": "api-extractor run --local"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
